{
  "$comment": "공유 하네스 설정. 개인 설정은 settings.local.json(.gitignore됨)에 둔다. 훅 경로는 프로젝트 루트 기준 상대경로다.",
  "permissions": {
    "allow": [
      "PowerShell(git status:*)",
      "PowerShell(git diff:*)",
      "PowerShell(git log:*)",
      "PowerShell(git add:*)",
      "PowerShell(git branch:*)",
      "PowerShell(git restore:*)",
      "PowerShell(& \"*Build.bat\"*)",
      "PowerShell(& \"*RunUAT.bat\"*)",
      "PowerShell(& \"*UnrealEditor.exe\"*)"
    ],
    "deny": [
      "Edit(**/Intermediate/**)",
      "Write(**/Intermediate/**)",
      "Edit(**/Binaries/**)",
      "Write(**/Binaries/**)",
      "Edit(**/DerivedDataCache/**)",
      "Write(**/DerivedDataCache/**)",
      "Edit(**/Saved/**)",
      "Write(**/Saved/**)",
      "Edit(**/*.generated.h)",
      "Write(**/*.generated.h)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".claude\\hooks\\guard-generated.ps1\""
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".claude\\hooks\\gate-pipeline.ps1\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".claude\\hooks\\format-source.ps1\""
          }
        ]
      }
    ]
  }
}
