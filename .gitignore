# ============================================================
# Unreal Engine 5 .gitignore (Bloodwake)
# ============================================================

# --- Build / 생성 산출물 (절대 커밋 금지) ---
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/

# --- IDE / 에디터 메타데이터 ---
.vs/
.vsconfig
.idea/
.vscode/
*.VC.db
*.VC.opendb
*.opensdf
*.sdf
*.suo
*.sln.docstates

# --- Visual Studio / Rider 생성 프로젝트 파일 ---
*.sln
*.xcodeproj
*.xcworkspace
*.workspace

# --- 컴파일 산출물 ---
*.obj
*.o
*.pdb
*.pch
*.exe
*.dll
*.lib
*.exp
*.app
*.ipa

# --- 패키징 / 배포 출력 ---
[Bb]uild/
[Bb]uilds/
Packaged/

# --- 자동 생성 헤더/소스 ---
*.generated.h
*.gen.cpp

# --- 크래시 / 로그 ---
*.log
*.dmp

# --- Claude Code 관련 (저장소 제외) ---
.claude/
docs/
Feature/
CLAUDE.md

# --- 블로그 글 (로컬 작성물 — 저장소 제외) ---
Blog/

# --- Unreal MCP 서버 관련 (저장소 제외) ---
# MCP 클라이언트 설정 (로컬 경로 포함 — 머신마다 다름)
.mcp.json
# chongdashu/unreal-mcp 클론 (Python 서버 + .venv)
/unreal-mcp/
# 프로젝트에 복사한 UnrealMCP 플러그인 (외부 도구 — 게임 산출물 아님)
/Plugins/UnrealMCP/
# MCP 서버 로그
unreal_mcp*.log

# --- OS 부산물 ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ============================================================
# 추적해야 하는 항목 (예외 — 위 규칙에 걸려도 강제 포함)
# ============================================================
!Config/**
!Content/**
!Source/**
!*.uproject
!*.Build.cs
!*.Target.cs
